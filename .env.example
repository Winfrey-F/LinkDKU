PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-long-random-secret

# Duke OAuth placeholders (fill these from your Duke OIT app credentials)
DUKE_OAUTH_CLIENT_ID=
DUKE_OAUTH_CLIENT_SECRET=
DUKE_OAUTH_AUTH_URL=https://oauth.oit.duke.edu/oidc/authorize
DUKE_OAUTH_TOKEN_URL=https://oauth.oit.duke.edu/oidc/token
DUKE_OAUTH_USERINFO_URL=https://oauth.oit.duke.edu/oidc/userinfo
DUKE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Matching schedule (UTC): run daily at 02:00 UTC by default
MATCH_CRON_MINUTE=0
MATCH_CRON_HOUR=2

# Database prep (current runtime still uses JSON storage)
DB_PROVIDER=json
DB_SQLITE_PATH=./data/linkdku.sqlite

# Admin dashboard login
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Email provider config
# Email mode: resend or smtp
EMAIL_PROVIDER=resend

# Resend API mode
EMAIL_API_KEY=
EMAIL_FROM=linkdku@duke.edu
EMAIL_API_HOST=api.resend.com
EMAIL_API_PATH=/emails

# Optional: force all match emails to one address (e.g. for testing). Leave blank to send to each user at netid@duke.edu.
EMAIL_TEST_TO=

# SMTP mode (Gmail example: use an App Password, not your normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
